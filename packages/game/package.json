{
  "name": "@rift-and-raid/game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./content/*": {
      "types": "./dist/content/*/index.d.ts",
      "import": "./dist/content/*/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b && bun run copy-content",
    "copy-content": "cp -r src/content dist/content 2>/dev/null || true",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rift-and-raid/shared": "*",
    "@rift-and-raid/engine": "*",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "bun-types": "^1.1.13",
    "vite": "^5.4.10"
  }
}
