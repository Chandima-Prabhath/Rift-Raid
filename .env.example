# Rift & Raid — environment variables
# Copy this file to .env and adjust as needed.
# .env is gitignored; .env.example is tracked so new clones know what's needed.

# SQLite database file path (relative to project root or absolute).
# Default: data/world.sqlite (created automatically)
DATABASE_URL=file:./data/world.sqlite

# Server port (Colyseus listens here in Phase 2+).
# Default: 2567
SERVER_PORT=2567

# Client dev server port (Vite).
# Default: 5173
CLIENT_PORT=5173

# Public URL the server is reachable at (used for client websocket connection).
# For LAN playtests: http://<your-LAN-IP>:2567
# For Cloudflare Tunnel: https://your-tunnel-url.trycloudflare.com
# Default: http://localhost:2567
PUBLIC_SERVER_URL=http://localhost:2567
