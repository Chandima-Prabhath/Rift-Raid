{
  "name": "rift-and-raid",
  "version": "0.1.0",
  "private": true,
  "description": "Rift & Raid — persistent-world, team-based 3D action RTS for the web",
  "workspaces": [
    "packages/shared",
    "packages/engine",
    "packages/game",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --filter='@rift-and-raid/server' run dev",
    "dev:client": "bun --filter='@rift-and-raid/client' run dev",
    "build": "bun run build:shared && bun run build:engine && bun run build:game && bun run build:server",
    "build:shared": "bun --filter='@rift-and-raid/shared' run build",
    "build:engine": "bun --filter='@rift-and-raid/engine' run build",
    "build:game": "bun --filter='@rift-and-raid/game' run build",
    "build:server": "bun --filter='@rift-and-raid/server' run build",
    "build:client": "bun --filter='@rift-and-raid/client' run build",
    "typecheck": "bun run typecheck:shared && bun run typecheck:engine && bun run typecheck:game && bun run typecheck:server",
    "typecheck:shared": "bun --filter='@rift-and-raid/shared' run typecheck",
    "typecheck:engine": "bun --filter='@rift-and-raid/engine' run typecheck",
    "typecheck:game": "bun --filter='@rift-and-raid/game' run typecheck",
    "typecheck:server": "bun --filter='@rift-and-raid/server' run typecheck",
    "test": "bun run test:smoke",
    "test:smoke": "bun tests/ecs-smoke.mjs",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}
